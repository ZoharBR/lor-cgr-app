import paramiko
import time
from django.utils import timezone
from devices.models import Device, DeviceBackup

def run_device_backup(device_id):
    """
    Conecta no equipamento via SSH, extrai a configuracao e salva
    com o nome: NomeDoEquipamento_ANO-MES-DIA_HORA-MINUTO.extensao
    
    CORRIGIDO: device.user -> device.username
    CORRIGIDO: Removido campo 'size' que nao existe no modelo
    """
    try:
        device = Device.objects.get(id=device_id)
        
        # Configura SSH
        ssh = paramiko.SSHClient()
        ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        ssh.connect(
            device.ip, 
            port=device.port, 
            username=device.username,
            password=device.password, 
            timeout=15,
            look_for_keys=False,
            allow_agent=False
        )

        config_output = ""
        file_extension = "txt"

        # === LOGICA MIKROTIK ===
        if device.vendor and 'mikrotik' in device.vendor.lower():
            file_extension = "rsc"
            stdin, stdout, stderr = ssh.exec_command('/export verbose')
            config_output = stdout.read().decode('utf-8', 'ignore')

        # === LOGICA HUAWEI ===
        elif device.vendor and 'huawei' in device.vendor.lower():
            file_extension = "cfg"
            channel = ssh.invoke_shell()
            channel.settimeout(10)
            
            commands = [
                'screen-length 0 temporary', 
                'display current-configuration'
            ]
            
            for cmd in commands:
                channel.send(cmd + '\n')
                time.sleep(0.5)
            
            time.sleep(3)
            
            while channel.recv_ready():
                config_output += channel.recv(9999).decode('utf-8', 'ignore')
        
        # === LOGICA CISCO ===
        elif device.vendor and 'cisco' in device.vendor.lower():
            file_extension = "cfg"
            channel = ssh.invoke_shell()
            channel.settimeout(10)
            
            commands = [
                'terminal length 0',
                'show running-config'
            ]
            
            for cmd in commands:
                channel.send(cmd + '\n')
                time.sleep(0.5)
            
            time.sleep(3)
            
            while channel.recv_ready():
                config_output += channel.recv(9999).decode('utf-8', 'ignore')

        # === LOGICA JUNIPER ===
        elif device.vendor and 'juniper' in device.vendor.lower():
            file_extension = "conf"
            stdin, stdout, stderr = ssh.exec_command('show configuration | display set')
            config_output = stdout.read().decode('utf-8', 'ignore')

        # === LOGICA GENERICA ===
        else:
            file_extension = "txt"
            try:
                stdin, stdout, stderr = ssh.exec_command('cat /etc/config/* 2>/dev/null || show running-config 2>/dev/null')
                config_output = stdout.read().decode('utf-8', 'ignore')
            except:
                pass

        ssh.close()

        if not config_output or len(config_output) < 50:
            raise Exception("O equipamento retornou um arquivo vazio ou muito curto.")

        # Salvar arquivo
        timestamp = timezone.now().strftime('%Y-%m-%d_%H-%M-%S')
        safe_name = device.name.replace(" ", "_")
        
        backup_dir = f"/opt/lorcgr/backups/{safe_name}"
        import os
        os.makedirs(backup_dir, exist_ok=True)
        
        filename = f"{safe_name}_{timestamp}.{file_extension}"
        filepath = os.path.join(backup_dir, filename)
        
        with open(filepath, 'w') as f:
            f.write(config_output)

        # Salvar no banco - SEM o campo size
        DeviceBackup.objects.create(
            device=device,
            file_path=filepath,
            status='success'
        )

        return True, f"Backup de {device.name} realizado com sucesso!"

    except Exception as e:
        try:
            device = Device.objects.get(id=device_id)
            DeviceBackup.objects.create(
                device=device,
                file_path='',
                status='failed'
            )
        except: pass
        
        return False, f"Erro ao fazer backup: {str(e)}"
